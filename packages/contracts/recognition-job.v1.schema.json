{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gatesight.example/contracts/recognition-job.v1.schema.json",
  "title": "RecognitionJob.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capture_id",
    "tenant_id",
    "facility_id",
    "station_id",
    "direction",
    "correlation_id",
    "s3_bucket",
    "s3_keys",
    "captured_at_client",
    "estimated_captured_at_server",
    "received_at_server",
    "facility_timezone"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "capture_id": {"type": "string"},
    "tenant_id": {"type": "string"},
    "facility_id": {"type": "string"},
    "station_id": {"type": "string"},
    "direction": {"enum": ["ENTRY", "EXIT"]},
    "correlation_id": {"type": "string"},
    "s3_bucket": {"type": "string"},
    "s3_keys": {"type": "array", "minItems": 3, "maxItems": 5, "items": {"type": "string"}},
    "captured_at_client": {"type": "string", "format": "date-time"},
    "estimated_captured_at_server": {"type": "string", "format": "date-time"},
    "received_at_server": {"type": "string", "format": "date-time"},
    "facility_timezone": {"type": "string"}
  }
}
