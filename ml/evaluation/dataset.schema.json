{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GateSight labeled evaluation dataset manifest",
  "type": "object",
  "required": ["name", "version", "license", "captures"],
  "properties": {
    "name": {"type": "string"},
    "version": {"type": "string"},
    "license": {"type": "string"},
    "captures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "captureId", "imagePaths", "expectedPlate", "region", "dayNight",
          "weather", "angle", "glare", "relativePlateSize", "plateType",
          "condition", "allowedUse", "provenance"
        ],
        "properties": {
          "captureId": {"type": "string"},
          "imagePaths": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "expectedPlate": {"type": ["string", "null"]},
          "boundingBoxes": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {"type": "number"}
            }
          },
          "region": {"type": "string"},
          "dayNight": {"enum": ["DAY", "NIGHT", "TWILIGHT"]},
          "weather": {"type": "string"},
          "angle": {"type": "string"},
          "glare": {"type": "string"},
          "distanceMeters": {"type": ["number", "null"]},
          "relativePlateSize": {"type": "number"},
          "plateType": {"enum": ["TEMPORARY", "PERMANENT", "UNKNOWN"]},
          "condition": {"type": "string"},
          "allowedUse": {"type": "string"},
          "provenance": {"type": "string"}
        }
      }
    }
  }
}
